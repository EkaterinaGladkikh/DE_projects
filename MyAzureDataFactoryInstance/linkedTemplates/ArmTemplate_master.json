{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "MyAzureDataFactoryInstance"
		},
		"LS_AzureSQL_IQAir_properties_typeProperties_connectionString_secretName": {
			"type": "string",
			"defaultValue": "sql-connection-string"
		},
		"LS_Databricks_IQAir_properties_typeProperties_existingClusterId": {
			"type": "string",
			"defaultValue": "0626-135412-w8rpdjfc"
		},
		"LS_KeyVault_IQAir_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://kv-iqair.vault.azure.net/"
		},
		"TR_Daily_IQAir_properties_PL_IQAir_MetadataDriven_Ingestion_parameters_environment": {
			"type": "string",
			"defaultValue": "dev"
		},
		"TR_Daily_IQAir_properties_PL_IQAir_MetadataDriven_Ingestion_parameters_bronze_enabled": {
			"type": "bool",
			"defaultValue": true
		},
		"TR_Daily_IQAir_properties_PL_IQAir_MetadataDriven_Ingestion_parameters_silver_enabled": {
			"type": "bool",
			"defaultValue": true
		},
		"TR_Daily_IQAir_properties_PL_IQAir_MetadataDriven_Ingestion_parameters_gold_enabled": {
			"type": "bool",
			"defaultValue": true
		},
		"TR_Daily_IQAir_properties_PL_IQAir_MetadataDriven_Ingestion_parameters_dq_enabled": {
			"type": "bool",
			"defaultValue": false
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "MyAzureDataFactoryInstance_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"LS_KeyVault_IQAir_properties_typeProperties_baseUrl": {
						"value": "[parameters('LS_KeyVault_IQAir_properties_typeProperties_baseUrl')]"
					},
					"LS_AzureSQL_IQAir_properties_typeProperties_connectionString_secretName": {
						"value": "[parameters('LS_AzureSQL_IQAir_properties_typeProperties_connectionString_secretName')]"
					},
					"LS_Databricks_IQAir_properties_typeProperties_existingClusterId": {
						"value": "[parameters('LS_Databricks_IQAir_properties_typeProperties_existingClusterId')]"
					},
					"TR_Daily_IQAir_properties_PL_IQAir_MetadataDriven_Ingestion_parameters_environment": {
						"value": "[parameters('TR_Daily_IQAir_properties_PL_IQAir_MetadataDriven_Ingestion_parameters_environment')]"
					},
					"TR_Daily_IQAir_properties_PL_IQAir_MetadataDriven_Ingestion_parameters_bronze_enabled": {
						"value": "[parameters('TR_Daily_IQAir_properties_PL_IQAir_MetadataDriven_Ingestion_parameters_bronze_enabled')]"
					},
					"TR_Daily_IQAir_properties_PL_IQAir_MetadataDriven_Ingestion_parameters_silver_enabled": {
						"value": "[parameters('TR_Daily_IQAir_properties_PL_IQAir_MetadataDriven_Ingestion_parameters_silver_enabled')]"
					},
					"TR_Daily_IQAir_properties_PL_IQAir_MetadataDriven_Ingestion_parameters_gold_enabled": {
						"value": "[parameters('TR_Daily_IQAir_properties_PL_IQAir_MetadataDriven_Ingestion_parameters_gold_enabled')]"
					},
					"TR_Daily_IQAir_properties_PL_IQAir_MetadataDriven_Ingestion_parameters_dq_enabled": {
						"value": "[parameters('TR_Daily_IQAir_properties_PL_IQAir_MetadataDriven_Ingestion_parameters_dq_enabled')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}